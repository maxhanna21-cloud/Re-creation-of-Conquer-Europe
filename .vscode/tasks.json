{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Watch: Auto-update codebase.txt",
            "type": "shell",
            "command": "while true; do sleep 30 && sh update_codebase.command; done",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": [],
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        }
    ]
}
