{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Watch: Auto-update split codebase",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "while true; do sleep 30; bash ./update_split.command; done"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": [],
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        }
    ]
}
