      "UnitManager": { "$path": "src/shared/UnitManager.luau" },
      "Auto-Fix": { "$path": "src/server/Auto-Fix.server.luau" },
      "CollisionSetup": { "$path": "src/server/CollisionSetup.server.luau" },
